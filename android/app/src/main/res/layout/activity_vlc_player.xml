<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/videoLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <!-- Controles superiores (título y volver) -->
    <LinearLayout
        android:id="@+id/top_controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@drawable/tv_exo_top_panel_background"
        android:layout_margin="16dp"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="visible">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/mobile_player_button_secondary"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/video_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/brightness_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="150dp"
        android:layout_height="20dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="-60dp"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:rotation="270"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/volume_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="150dp"
        android:layout_height="20dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="-60dp"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:rotation="270"
        android:visibility="gone" />

    <!-- Barra de progreso para desbloqueo de pantalla -->
    <ProgressBar
        android:id="@+id/unlock_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="200dp"
        android:layout_height="8dp"
        android:layout_centerInParent="true"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:visibility="gone"
        android:max="100" />

    <!-- CONTENEDOR PRINCIPAL DE CONTROLES (Ahora abarca toda la pantalla para centrar los botones principales) -->
    <RelativeLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <!-- BOTONES DE REPRODUCCIÓN EN EL CENTRO -->
        <LinearLayout
            android:id="@+id/center_playback_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/prev_episode_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_prev"
                android:background="@drawable/mobile_player_button_secondary"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="Episodio Anterior"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/rewind_button"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_rewind"
                android:background="@drawable/mobile_player_button_secondary"
                android:layout_marginStart="20dp"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:contentDescription="Rewind"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/play_pause_button"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/mobile_player_button_primary"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:padding="14dp"
                android:scaleType="fitCenter"
                android:contentDescription="Play/Pause" />

            <ImageButton
                android:id="@+id/forward_button"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_forward"
                android:background="@drawable/mobile_player_button_secondary"
                android:layout_marginEnd="20dp"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:contentDescription="Forward"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/next_episode_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_next"
                android:background="@drawable/mobile_player_button_secondary"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="Siguiente Episodio"
                android:visibility="gone" />
        </LinearLayout>

        <!-- PANEL DE CONTROLES INFERIORES -->
        <LinearLayout
            android:id="@+id/bottom_controls_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="16dp"
            android:background="@drawable/tv_exo_bottom_panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Fila del SeekBar y los tiempos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/currentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DDFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:text="00:00" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:progressDrawable="@drawable/tv_exo_seekbar_progress"
                    android:thumb="@drawable/tv_exo_seekbar_thumb"
                    android:thumbOffset="8dp"
                    android:splitTrack="false"
                    android:maxHeight="10dp"
                    android:minHeight="10dp" />

                <TextView
                    android:id="@+id/totalDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DDFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:text="00:00" />
            </LinearLayout>

            <!-- Fila de opciones secundarias -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/tracks_button"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_tracks"
                        android:background="@drawable/mobile_player_button_secondary"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Audio/Subtitles" />

                    <ImageButton
                        android:id="@+id/aspect_ratio_button"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_aspect_ratio"
                        android:background="@drawable/mobile_player_button_secondary"
                        android:layout_marginStart="12dp"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Aspect Ratio" />

                    <ImageButton
                        android:id="@+id/speed_button"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_speed"
                        android:background="@drawable/mobile_player_button_secondary"
                        android:layout_marginStart="12dp"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Velocidad de reproducción" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/channels_button"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_channels"
                        android:background="@drawable/mobile_player_button_secondary"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Channel List" />

                    <ImageButton
                        android:id="@+id/lock_button"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_lock"
                        android:background="@drawable/mobile_player_button_secondary"
                        android:layout_marginStart="12dp"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Bloquear Pantalla" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
