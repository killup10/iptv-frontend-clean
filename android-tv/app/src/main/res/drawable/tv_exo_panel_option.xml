<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="18dp" />
                    <gradient
                        android:angle="0"
                        android:endColor="@color/tv_exo_neon_pink"
                        android:startColor="@color/tv_exo_neon_purple" />
                </shape>
            </item>
            <item
                android:bottom="2dp"
                android:left="2dp"
                android:right="2dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <gradient
                        android:angle="90"
                        android:endColor="#EEBF1BFF"
                        android:startColor="#EE7A39FF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="0"
                android:endColor="#ECBF1BFF"
                android:startColor="#F07A39FF" />
            <stroke android:width="1.5dp" android:color="#B4FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#180B1220" />
            <stroke android:width="1dp" android:color="#28FFFFFF" />
        </shape>
    </item>
</selector>
