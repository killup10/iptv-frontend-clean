<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/videoLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <!-- Controles superiores (título) -->
    <LinearLayout
        android:id="@+id/top_controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@drawable/tv_exo_top_panel_background"
        android:layout_margin="24dp"
        android:padding="12dp"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/video_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="2"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/brightness_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="150dp"
        android:layout_height="20dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="-60dp"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:rotation="270"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/volume_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="150dp"
        android:layout_height="20dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="-60dp"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:rotation="270"
        android:visibility="gone" />

    <!-- Barra de progreso para desbloqueo de pantalla -->
    <ProgressBar
        android:id="@+id/unlock_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="200dp"
        android:layout_height="8dp"
        android:layout_centerInParent="true"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:visibility="gone"
        android:max="100" />

    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/tv_exo_bottom_panel_background"
        android:layout_margin="24dp"
        android:orientation="vertical"
        android:padding="20dp">

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/play_pause_button"
            android:nextFocusLeft="@id/seekBar"
            android:nextFocusRight="@id/seekBar" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/currentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:layout_alignParentStart="true"
                android:text="00:00" />

            <TextView
                android:id="@+id/totalDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:layout_alignParentEnd="true"
                android:text="00:00" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <ImageButton
                android:id="@+id/tracks_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_tracks"
                android:background="@drawable/tv_exo_transport_secondary"
                android:focusable="true"
                android:layout_alignParentStart="true"
                android:contentDescription="Audio/Subtitles" />

            <ImageButton
                android:id="@+id/aspect_ratio_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_aspect_ratio"
                android:background="@drawable/tv_exo_transport_secondary"
                android:focusable="true"
                android:layout_toEndOf="@id/tracks_button"
                android:layout_marginStart="16dp"
                android:contentDescription="Aspect Ratio" />

            <ImageButton
                android:id="@+id/speed_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_speed"
                android:background="@drawable/tv_exo_transport_secondary"
                android:focusable="true"
                android:layout_toEndOf="@id/aspect_ratio_button"
                android:layout_marginStart="16dp"
                android:contentDescription="Velocidad de reproducción" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/prev_episode_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_prev"
                    android:background="@drawable/tv_exo_transport_secondary"
                    android:focusable="true"
                    android:contentDescription="Episodio Anterior"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/rewind_button"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/tv_seek_action_button"
                    android:layout_marginStart="16dp"
                    android:contentDescription="Retroceder 10 segundos"
                    android:gravity="center"
                    android:text="10-"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/play_pause_button"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_play"
                    android:background="@drawable/tv_exo_transport_primary"
                    android:focusable="true"
                    android:layout_marginStart="32dp"
                    android:layout_marginEnd="32dp"
                    android:contentDescription="Play/Pause" />

                <Button
                    android:id="@+id/forward_button"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/tv_seek_action_button"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Adelantar 10 segundos"
                    android:gravity="center"
                    android:text="10+"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/next_episode_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_next"
                    android:background="@drawable/tv_exo_transport_secondary"
                    android:focusable="true"
                    android:contentDescription="Siguiente Episodio"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/channels_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_channels"
                    android:background="@drawable/tv_exo_transport_secondary"
                    android:focusable="true"
                    android:contentDescription="Channel List" />

                <ImageButton
                    android:id="@+id/lock_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_lock_lock"
                    android:background="@drawable/tv_exo_transport_secondary"
                    android:focusable="false"
                    android:visibility="gone"
                    android:layout_marginStart="16dp"
                    android:contentDescription="Bloquear Pantalla"
                    android:tint="@android:color/white" />
            </LinearLayout>
        </RelativeLayout>

    </LinearLayout>

</RelativeLayout>
