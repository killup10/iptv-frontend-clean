<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:keep_content_on_player_reset="true"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:use_controller="false" />

    <View
        android:id="@+id/top_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="1"
        android:background="@drawable/tv_exo_top_scrim" />

    <View
        android:id="@+id/bottom_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="1"
        android:background="@drawable/tv_exo_bottom_scrim" />

    <LinearLayout
        android:id="@+id/top_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:baselineAligned="false"
        android:gravity="top"
        android:orientation="horizontal"
        android:paddingStart="56dp"
        android:paddingTop="36dp"
        android:paddingEnd="48dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxWidth="820dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/content_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tv_exo_meta_chip"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp"
                    android:text="SERIE"
                    android:textAllCaps="true"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/episode_context"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="#DDE8FF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/video_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="16"
                android:textColor="@android:color/white"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/video_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="10"
                android:textColor="#E2ECFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/video_meta_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="#BFD0EA"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/clock_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/selection_panel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="56dp"
        android:layout_marginBottom="232dp"
        android:alpha="0"
        android:background="@drawable/tv_exo_panel_background"
        android:elevation="18dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/selection_panel_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/selection_panel_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#9FB6D4"
            android:textSize="12sp"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/selection_panel_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fadingEdge="none"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:overScrollMode="never"
            android:scrollbarStyle="outsideOverlay">

            <LinearLayout
                android:id="@+id/selection_panel_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="22dp"
        android:alpha="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/transport_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/prev_episode_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/tv_exo_transport_secondary"
                android:drawableTop="@android:drawable/ic_media_previous"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text=""
                android:textAllCaps="false" />

            <Button
                android:id="@+id/play_pause_button"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:background="@drawable/tv_exo_transport_primary"
                android:drawableTop="@android:drawable/ic_media_play"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text=""
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/next_episode_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/tv_exo_transport_secondary"
                android:drawableTop="@android:drawable/ic_media_next"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text=""
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/progress_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/current_time"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_weight="1"
                android:clickable="false"
                android:enabled="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:max="10000"
                android:padding="0dp"
                android:progressDrawable="@drawable/tv_exo_seekbar_progress"
                android:splitTrack="false"
                android:thumb="@drawable/tv_exo_seekbar_thumb"
                android:thumbOffset="0dp" />

            <TextView
                android:id="@+id/total_duration"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actions_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/rewind_button"
                android:layout_width="112dp"
                android:layout_height="76dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tv_exo_action_tile"
                android:drawableTop="@android:drawable/ic_media_rew"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:lines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:stateListAnimator="@null"
                android:text="-10s&#10;Retroceso"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/forward_button"
                android:layout_width="112dp"
                android:layout_height="76dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tv_exo_action_tile"
                android:drawableTop="@android:drawable/ic_media_ff"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:lines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:stateListAnimator="@null"
                android:text="+10s&#10;Avance"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/tracks_button"
                android:layout_width="120dp"
                android:layout_height="76dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tv_exo_action_tile"
                android:drawableTop="@android:drawable/ic_menu_sort_by_size"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:lines="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:stateListAnimator="@null"
                android:text="Audio / Sub"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/speed_button"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tv_exo_action_tile"
                android:drawableTop="@android:drawable/ic_menu_recent_history"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:lines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:stateListAnimator="@null"
                android:text="Velocidad&#10;1.0x"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/aspect_ratio_button"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tv_exo_action_tile"
                android:drawableTop="@android:drawable/ic_menu_crop"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:lines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:stateListAnimator="@null"
                android:text="Aspecto&#10;Ajustar"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/channels_button"
                android:layout_width="120dp"
                android:layout_height="76dp"
                android:background="@drawable/tv_exo_action_tile"
                android:drawableTop="@android:drawable/ic_menu_agenda"
                android:drawableTint="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:lines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:stateListAnimator="@null"
                android:text="Episodios&#10;Lista"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/control_hint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DPAD Navegar  |  OK Seleccionar  |  BACK Salir"
                android:textColor="#9FB2D3"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEAMG"
                    android:textColor="#28D7FF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="PLAY"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/lock_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/tv_exo_lock_message_background"
        android:elevation="14dp"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:textColor="@android:color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>
